# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by Supabase Auth for redirect URLs. Must match your Supabase project's Site URL setting.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Services (Call Summarizer)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Google Service Account (Agreements Module — Docs + Drive API)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Shared Drive folder ID where generated agreement PDFs land (service accounts have 0 personal storage)
GOOGLE_DRIVE_SHARED_FOLDER_ID=
