# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used by Supabase Auth for redirect URLs. Must match your Supabase project's Site URL setting.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Services (Call Summarizer)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
