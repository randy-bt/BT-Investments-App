# BT Investments app — every environment variable the code reads.
# Copy to .env.local for dev; production values live in Vercel
# (managed via `npx vercel env`). NEVER commit real values — public repo.
#
# ⚠️ Vercel quirk: some stored values carry a literal trailing "\n".
# Server code strips it via the env helpers in lib/quo.ts / lib/billing.ts;
# strip defensively when reading a new var: .replace(/\\n$/, '').trim()

# ── Supabase (core — app does not start without these) ──────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-SIDE ONLY. Never prefix with NEXT_PUBLIC_. Bypasses Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=

# ── App URLs ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Must match the Supabase project's Site URL setting (auth redirects).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI inference ─────────────────────────────────────────────────────────
# Anthropic key "CC Onboarding Summarizer": call summaries, deal snapshots,
# briefs, contract AI review, Indica chat. Missing → those buttons error.
ANTHROPIC_API_KEY=
# Separate Anthropic key "BTi App - News Module": news scoring/rewrites/
# headlines + market data. Missing → daily news cron degrades.
NEWS_ANTHROPIC_API_KEY=
# OpenAI: property scraper (gpt-4o + web search) and call transcription.
OPENAI_API_KEY=

# ── Billing dashboards (read-only ADMIN keys — usage monitor "Actual API
#    Spend" box; different key type from the inference keys above) ───────
ANTHROPIC_ADMIN_KEY=
OPENAI_ADMIN_KEY=

# ── Email (Resend; domain btinvestments.co verified, DNS on Vercel) ─────
# Form notifications, direct sends from lead/investor records, cron alerts.
RESEND_API_KEY=

# ── Quo (OpenPhone) SMS ──────────────────────────────────────────────────
# Raw key goes in the Authorization header (no "Bearer").
QUO_API_KEY=
# E.164, e.g. +12065551234 — the business line texts are sent from.
QUO_FROM_NUMBER=
# Optional override of the API base (defaults to https://api.openphone.com/v1).
# QUO_API_BASE=

# ── Google Maps / Places ─────────────────────────────────────────────────
# Address autocomplete + map embeds on marketing pages. Requires Google
# Cloud billing enabled; when billing is off, autocomplete degrades and
# maps fall back to the free Embed API.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ── Google Service Account (Agreements module — Docs + Drive APIs) ──────
# bt-agreements-generator@... has Editor access to both PSA templates.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# Shared Drive folder where generated agreement PDFs land (service accounts
# have no personal storage).
GOOGLE_DRIVE_SHARED_FOLDER_ID=

# ── Crons (Vercel sends "Authorization: Bearer $CRON_SECRET") ────────────
# Auth for /api/news/refresh and /api/jv/scan. Checked via lib/cron-health.
CRON_SECRET=

# ── News sources (daily news cron) ───────────────────────────────────────
NEWS_API_KEY=
# FRED (Federal Reserve) economic stats for the market data section.
FRED_API_KEY=

# ── ElevenLabs (News "Read Aloud" TTS) ───────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ── JV Deal Inbox email intake (DORMANT until go-live) ───────────────────
# Also requires app_settings: jv_intake_enabled='true', jv_start_cutoff,
# jv_last_uid='0'. Cron is daily (Vercel Hobby limit).
JV_IMAP_HOST=
JV_IMAP_USER=
JV_IMAP_PASSWORD=

# ── Personal digest (randydigest@gmail.com IMAP; Randy-only) ─────────────
DIGEST_GMAIL_USER=
DIGEST_GMAIL_APP_PASSWORD=

# ── Auto-generated (do not set manually) ─────────────────────────────────
# VERCEL_OIDC_TOKEN — written by `vercel env pull` for local dev only.
